<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_alignParentTop="true"
        app:cardCornerRadius="8dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cerca_parcheggi"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="🔍 Filtra Ricerca"
                    android:textAlignment="viewStart"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="#37474F"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/loading_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txt_criteri_attivi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tutti i parcheggi vicini"
                android:padding="8dp"
                android:textSize="12sp"
                android:textColor="#78909C"
                android:background="#FAFAFA"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_results"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/card_search"
        android:layout_marginHorizontal="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:visibility="gone"/>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_centra_posizione"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="#FFFFFF"
        app:tint="#2962FF"/>

</RelativeLayout>