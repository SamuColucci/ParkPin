<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#212121"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#424242"
            android:layout_marginBottom="20dp"/>

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D32F2F"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/txt_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rimuovere Scadenza?"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="-0.01"/>

        <TextView
            android:id="@+id/txt_dialog_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="La notifica verrà cancellata e non riceverai l'avviso."
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:lineSpacingExtra="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_annulla_delete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Annulla"
                android:textColor="#BDBDBD"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_conferma_delete"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1.6"
                android:text="RIMUOVI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#D32F2F"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart"
                app:iconSize="18dp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>