<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtra Parcheggi"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#263238"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cerca Nome o Via (es. Garibaldi)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_filtro_nome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipologia:"
        android:textSize="14sp"
        android:textColor="#546E7A"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rg_costo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_tutti"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tutti"
            android:checked="true"
            android:layout_marginEnd="12dp"/>

        <RadioButton
            android:id="@+id/rb_gratis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gratis"
            android:textColor="#388E3C"
            android:layout_marginEnd="12dp"/>

        <RadioButton
            android:id="@+id/rb_pagamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pagamento"
            android:textColor="#D32F2F"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_applica_filtri"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="CERCA ORA 🔍"
        app:cornerRadius="12dp"
        app:backgroundTint="#2962FF"/>

</LinearLayout>